{
  "name": "Medusa",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "backend-server",
  "workspaceFolder": "/workspace",
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb"
  },
  "remoteUser": "ubuntu",
  "updateRemoteUserUID": true,
  "overrideCommand": true,
  "shutdownAction": "stopCompose",
  // CRÍTICO PARA CLI: Indica que debe levantar AMBOS servicios al iniciar.
  "runServices": [
    "postgres",
    "redis"
  ],
  // Nos conectamos al contenedor como usuario 'node'
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "ubuntu",
      "userUid": "1000",
      "userGid": "1000",
      "installZsh": true,
      "upgradePackages": false
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {
      "packages": "git,wget,curl,ripgrep,xclip,sudo,iputils-ping,procps"
    },
    "ghcr.io/danzilberdan/devcontainers/opencode:0": {},
    "ghcr.io/duduribeiro/devcontainer-features/neovim:1": {
            "version": "stable"
        }
  },
  "mounts": [
    {
      "source": "${localWorkspaceFolder}/.opencode/auth.json",
      "target": "/mnt/opencode-auth.json",
      "type": "bind"
    }
  ],
  "postCreateCommand": "bash -lc 'sudo chown -R ubuntu:ubuntu /home/ubuntu/.local /home/ubuntu/.config /home/ubuntu/.cache && corepack enable pnpm && pnpm install && pnpm playwright:install && if [ -f /mnt/opencode-auth.json ]; then sudo chown ubuntu:ubuntu /mnt/opencode-auth.json; fi'",
  // Puertos que la CLI de devcontainers expondrá (si aplica en tu entorno)
  "forwardPorts": [
    9000,
    8088
  ]
}
